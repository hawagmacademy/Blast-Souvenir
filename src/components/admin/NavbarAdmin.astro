---
const { currentLocale, lang, active = 'dashboard' } = Astro.props;
const effectiveLang = lang || currentLocale;
const dashboardLink = `/blast/${effectiveLang}/admin`;
const blogLink = `/blast/${effectiveLang}/admin/blog`;
const pesanLink = `/blast/${effectiveLang}/admin/pesan`;
---

<nav class="admin-navbar bg-slate-900 text-slate-100 shadow-[0_10px_30px_rgba(15,23,42,0.18)]">
  <div class="admin-navbar-inner">
    <div class="navbar-brand">
      <span class="brand-dot bg-sky-500"></span>
      <span class="brand-text">Admin Dashboard</span>
    </div>
    <div class="navbar-links">
      <a href={dashboardLink} class={`nav-link nav-button ${active === 'dashboard' ? 'active-tab' : ''}`}>Dashboard</a>
      <a href={blogLink} class={`nav-link nav-button ${active === 'blog' ? 'active-tab' : ''}`}>Blog</a>
      <a href={pesanLink} class={`nav-link nav-button ${active === 'pesan' ? 'active-tab' : ''}`}>Daftar Pesan Masuk</a>
    </div>
  </div>
</nav>

<style>
  .admin-navbar {
    width: 100%;
    background: #0f172a;
    color: white;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .admin-navbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .navbar-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #f8fafc;
    font-size: 1rem;
  }

  .brand-dot {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 9999px;
    box-shadow: 0 0 0 5px rgba(56,189,248,0.12);
  }

  .brand-text {
    color: #f8fafc;
    font-size: 1.05rem;
  }

  .navbar-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .nav-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.1rem;
    border-radius: 0.75rem;
    font-weight: 600;
    color: #cbd5e1;
    text-decoration: none;
    background: rgba(255,255,255,0.03);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .nav-button:hover {
    background: rgba(148,163,184,0.22);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .nav-button.active-tab {
    background: rgba(56, 189, 248, 0.16);
    color: #ffffff;
    box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.2);
  }
</style>
