---
import Layout from '@layouts/Layout.astro';
import Cta from '@components/pricing/Cta.astro';
import Faq from '@components/pricing/Faq.astro';
import Heading from '@components/pricing/Heading.astro';
import { getLabels, getStaticPaths } from '@i18n/utils';

import { supabase } from '../../lib/db.js';

export { getStaticPaths };

// 2. Ambil info bahasa dari URL dan label i18n bawaan template
const { lang } = Astro.params;
const labels = getLabels(Astro.currentLocale, 'pricing');

type Souvenir = {
  id: number;
  foto: string;
  nama: string;
  harga: number;
  min_order: number;
};

// 3. Proses pengambilan data dari database
let daftarSouvenir: Souvenir[] = [];
try {
  const { data, error } = await supabase.from('souvenirs').select('*');
  if (error) throw error;
  daftarSouvenir = data as Souvenir[];
} catch (error) {
  console.error("Gagal memuat souvenir:", error);
}
---

<Layout description={labels.description} title={labels.title}>
  <Heading />

  <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-8 max-w-[1200px] mx-auto px-4 my-12">
    {daftarSouvenir.map((produk) => (
      <div class="flex flex-col border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden shadow-sm hover:shadow-md bg-white dark:bg-[#1e293b] transition-all duration-300">
        <img src={produk.foto} alt={produk.nama} class="w-full h-[200px] object-cover" />
        <div class="p-6 flex flex-col grow">
          <h3 class="text-xl font-bold mb-2 text-[#1a202c] dark:text-white transition-colors">{produk.nama}</h3>
          <p class="font-bold text-[#3182ce] dark:text-blue-400 mb-2 transition-colors">Harga: Rp {produk.harga.toLocaleString('id-ID')} / pcs</p>
          <p class="text-sm text-[#718096] dark:text-slate-400 mb-6 transition-colors">Min. Order: {produk.min_order} pcs</p>
          <a href={`/${lang || Astro.currentLocale}/contact?produk=${produk.id}`} class="block text-center bg-[#3182ce] hover:bg-[#2b6cb0] text-white font-bold py-3 px-4 rounded-lg mt-auto transition-colors">
            Pesan Sekarang
          </a>
        </div>
      </div>
    ))}
  </div>

  <Faq />
  <Cta />
</Layout>