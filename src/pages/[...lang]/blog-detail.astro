---
import Layout from '@layouts/Layout.astro';
import { supabase } from '../../lib/db.js';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { defaultLocale } from '@i18n/utils';
export { getStaticPaths } from '@i18n/utils';
export const prerender = false;

const currentLocale = Astro.currentLocale || defaultLocale;
const basePath = (import.meta.env.BASE_URL ?? '/blast').replace(/\/$/, '');
const slug = String(Astro.url.searchParams.get('slug') || '').trim();

type Post = {
  id: number;
  title?: string | null;
  slug?: string | null;
  excerpt?: string | null;
  image_url?: string | null;
  content?: string | null;
  created_at?: string | null;
  published_at?: string | null;
};

let post: Post | null = null;
let allPosts: Post[] = [];

if (slug) {
  const { data, error } = await supabase.from('posts').select('*').eq('slug', slug).single();
  if (!error && data) {
    post = data as Post;
  }
}

// Ambil semua post untuk Related Posts & Baca Juga
try {
  const { data, error } = await supabase.from('posts').select('*').order('id', { ascending: false });
  if (!error && data) {
    allPosts = (data as Post[]).filter(p => p.slug !== slug);
  }
} catch (e) {
  console.error('Gagal memuat daftar post:', e);
}

// Related posts: 3 artikel terbaru (selain artikel ini)
const relatedPosts = allPosts.slice(0, 3);

// "Baca Juga": 1 artikel random dari sisa (selain related & current)
const bacaJugaCandidates = allPosts.length > 3 ? allPosts.slice(3) : allPosts.slice(0, 1);
const bacaJugaPost = bacaJugaCandidates.length > 0
  ? bacaJugaCandidates[Math.floor(Math.random() * bacaJugaCandidates.length)]
  : (allPosts.length > 0 ? allPosts[0] : null);

const formatDate = (value?: string | null) => {
  if (!value) return '-';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleDateString('id-ID', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
};

import { marked } from 'marked';

// Konfigurasi marked agar mendukung single line breaks jika diperlukan
marked.setOptions({
  breaks: true,
  gfm: true
});

/**
 * Fungsi Pintar untuk membersihkan dan menata teks yang berantakan (tanpa enter/format).
 * Mengotomatisasi pembuatan <p>, <h2>, <h3>, <ul>, <li>, dan <strong>.
 */
function smartFormat(text: string) {
  if (!text) return '';
  let str = text;

  // 1. Deteksi Heading H2 (Pertanyaan Utama)
  // Mencari kalimat tanya (Tanda Tanya diakhiri spasi) dan mengubahnya jadi ##
  str = str.replace(/(?:^|[\.\\?]\s+)([A-Z][^\.]+?\?)(?=\s+[A-Z])/g, (match, p1) => {
    return `\n\n## ${p1}\n\n`;
  });

  // 2. Deteksi Subjudul H3 / Kata Penting yang diikuti titik dua
  // Contoh: "Apresiasi Karyawan (Employee Engagement):" -> ### Apresiasi Karyawan...
  str = str.replace(/(?:^|[\.\\?]\s+)([A-Z][a-zA-Z\s\(\)]+:)\s+(?=[A-Z])/g, (match, p1) => {
    return `\n\n### ${p1.replace(':', '')}\n\n`;
  });

  // 3. Deteksi Poin-Poin/Daftar Angka (1. , 2. , 3. )
  str = str.replace(/(?:^|[\.\\?]\s+)(\d+\.\s+[A-Z])/g, (match, p1) => {
    return `\n${p1}`;
  });

  // 4. Deteksi Kata Penting untuk ditebalkan (<strong>)
  // Misal: "Top of mind", "Welcome kit"
  const importantWords = ['Brand Awareness', 'Top of mind', 'Welcome kit', 'Employee Engagement'];
  importantWords.forEach(word => {
    const regex = new RegExp(`\\b(${word})\\b`, 'gi');
    str = str.replace(regex, '**$1**');
  });

  // Memaksa single newline (\n) menjadi double newline (\n\n) agar marked membungkusnya jadi <p>
  // kecuali jika baris tersebut adalah bagian dari list (angka/strip)
  const lines = str.replace(/\r\n/g, '\n').split('\n');
  const spacedLines = lines.map(line => {
    const t = line.trim();
    if (t.match(/^(#|\d+\.|-|\*)/)) {
      return t;
    }
    return t ? `${t}\n` : ''; 
  });

  return spacedLines.join('\n').replace(/\n{3,}/g, '\n\n');
}

// Pastikan post.content diproses dulu oleh smartFormat, baru di-parse oleh marked
const rawText = post ? (post.content || '') : '';
const formattedText = smartFormat(rawText);
let parsedContent = await marked.parse(formattedText);

// ======= TOC: Parse headings & inject IDs =======
type TocEntry = {
  id: string;
  text: string;
  level: number;
};

const tocItems: TocEntry[] = [];
let headingCounter = 0;

// Tambah ID ke setiap <h2> dan <h3>, dan kumpulkan untuk TOC
parsedContent = parsedContent.replace(/<(h[23])>(.*?)<\/\1>/gi, (match, tag, text) => {
  headingCounter++;
  const cleanText = text.replace(/<[^>]+>/g, '').trim();
  const id = `heading-${headingCounter}`;
  const level = tag.toLowerCase() === 'h2' ? 2 : 3;
  tocItems.push({ id, text: cleanText, level });
  return `<${tag} id="${id}">${text}</${tag}>`;
});

// ======= Sisipkan "Baca Juga" di tengah konten =======
let contentWithBacaJuga = parsedContent;
if (bacaJugaPost && bacaJugaPost.slug) {
  const bacaJugaUrl = `${basePath}/${currentLocale}/blog-detail?slug=${encodeURIComponent(bacaJugaPost.slug)}`;
  const bacaJugaHtml = `
    <aside class="my-8 rounded-xl border-l-4 border-sky-500 bg-sky-50 dark:border-sky-500 dark:bg-sky-900/20 p-5 shadow-sm transition-all hover:shadow-md">
      <div class="flex items-center gap-2.5 mb-1.5">
        <svg class="h-5 w-5 text-sky-600 dark:text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <span class="text-[11px] font-black uppercase tracking-widest text-sky-600 dark:text-sky-400">Baca Juga</span>
      </div>
      <a href="${bacaJugaUrl}" class="group block text-lg font-bold leading-snug text-slate-800 transition-colors hover:text-sky-600 dark:text-slate-100 dark:hover:text-sky-400">
        ${bacaJugaPost.title || 'Artikel Lainnya'}
        <span class="inline-block transition-transform group-hover:translate-x-1 ml-1">&rarr;</span>
      </a>
    </aside>
  `;

  // Sisipkan setelah paragraf ke-3 secara aman
  let pCount = 0;
  contentWithBacaJuga = contentWithBacaJuga.replace(/<\/p>/g, (match) => {
    pCount++;
    if (pCount === 3) {
      return match + '\n' + bacaJugaHtml;
    }
    return match;
  });
  
  // Jika artikel sangat pendek (1-2 paragraf), sisipkan setelah paragraf pertama
  if (pCount > 1 && pCount < 3) {
    let midCount = 0;
    contentWithBacaJuga = parsedContent.replace(/<\/p>/g, (match) => {
      midCount++;
      if (midCount === 1) {
        return match + '\n' + bacaJugaHtml;
      }
      return match;
    });
  }
}
---

<Layout description={post?.excerpt || post?.title || 'Detail artikel blog'} title={post?.title ?? 'Blog Detail'}>
  <section class="mx-auto max-w-6xl py-10 px-4 sm:px-6 lg:px-8">
    <a
      href={`${basePath}/${currentLocale}/blog`}
      class="inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm transition hover:border-slate-300 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:hover:bg-slate-900"
    >
      &lt; Kembali ke Blog
    </a>

    {post ? (
      <article class="mt-10">
        <!-- Hero Image -->
        <div class="overflow-hidden rounded-2xl bg-slate-100 shadow-md dark:bg-slate-800 mb-8">
          <img
            src={post.image_url ?? `${basePath}/placeholder.jpg`}
            alt={post.title ?? 'Artikel blog'}
            class="w-full max-h-[480px] object-cover"
          />
        </div>

        <!-- Meta Info -->
        <div class="mb-8 space-y-4">
          <div class="text-sm font-semibold uppercase tracking-[0.25em] text-sky-600">Blog</div>
          <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-slate-100 lg:text-5xl">{post.title ?? 'Tanpa Judul'}</h1>
          <div class="flex items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
            <span>{formatDate(post.published_at ?? post.created_at)}</span>
            {post.excerpt && (
              <Fragment>
                <span class="hidden sm:inline text-slate-300 dark:text-slate-600">|</span>
                <span class="hidden sm:inline italic text-slate-400 dark:text-slate-500">{post.excerpt}</span>
              </Fragment>
            )}
          </div>
        </div>

        <!-- Main Grid: TOC + Content -->
        <div class="grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-10">
          
          <!-- TOC Sidebar (Desktop) -->
          {tocItems.length > 0 && (
            <aside class="hidden lg:block">
              <nav class="sticky top-8" id="toc-nav">
                <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-950">
                  <h2 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Daftar Isi</h2>
                  <ul class="space-y-1 text-sm" id="toc-list">
                    {tocItems.map(item => (
                      <li>
                        <a
                          href={`#${item.id}`}
                          class={`toc-link block rounded-lg px-3 py-2 font-medium transition-colors hover:bg-sky-50 hover:text-sky-700 dark:hover:bg-sky-500/10 dark:hover:text-sky-400 ${item.level === 3 ? 'pl-6 text-slate-400 dark:text-slate-500 text-[13px]' : 'text-slate-600 dark:text-slate-300'}`}
                          data-target={item.id}
                        >
                          {item.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </nav>
            </aside>
          )}

          <!-- Article Content -->
          <div class={tocItems.length > 0 ? '' : 'lg:col-span-2 max-w-3xl mx-auto'}>
            <!-- TOC Mobile (Collapsible) -->
            {tocItems.length > 0 && (
              <details class="lg:hidden mb-8 rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-950 overflow-hidden">
                <summary class="flex cursor-pointer items-center gap-2 p-4 text-sm font-bold text-slate-700 dark:text-slate-200 select-none">
                  <svg class="w-4 h-4 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
                  Daftar Isi
                </summary>
                <ul class="px-4 pb-4 space-y-1 text-sm">
                  {tocItems.map(item => (
                    <li>
                      <a
                        href={`#${item.id}`}
                        class={`block rounded-lg px-3 py-2 font-medium transition-colors hover:bg-sky-50 hover:text-sky-700 dark:hover:bg-sky-500/10 dark:hover:text-sky-400 ${item.level === 3 ? 'pl-6 text-slate-400 dark:text-slate-500 text-[13px]' : 'text-slate-600 dark:text-slate-300'}`}
                      >
                        {item.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            )}

            <!-- Artikel Content -->
            <div class="prose prose-slate dark:prose-invert max-w-none prose-content" set:html={contentWithBacaJuga}>
            </div>
          </div>
        </div>

        <!-- Related Posts Section -->
        {relatedPosts.length > 0 && (
          <section class="mt-16 pt-12 border-t border-slate-200 dark:border-slate-700">
            <div class="mb-8 text-center">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-sky-600 mb-2">Rekomendasi</p>
              <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Artikel Terkait</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {relatedPosts.map(rp => (
                <a
                  href={`${basePath}/${currentLocale}/blog-detail?slug=${encodeURIComponent(rp.slug ?? '')}`}
                  class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg dark:border-slate-800 dark:bg-slate-950"
                >
                  <div class="aspect-[4/3] overflow-hidden bg-slate-100 dark:bg-slate-800">
                    {rp.image_url ? (
                      <img
                        src={rp.image_url}
                        alt={rp.title ?? 'Artikel'}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : (
                      <div class="h-full w-full flex items-center justify-center">
                        <svg class="w-10 h-10 text-slate-300 dark:text-slate-700" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"></path></svg>
                      </div>
                    )}
                  </div>
                  <div class="flex flex-1 flex-col p-5">
                    <span class="mb-2 text-[11px] font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">{formatDate(rp.published_at ?? rp.created_at)}</span>
                    <h3 class="text-base font-semibold leading-snug text-slate-900 dark:text-slate-100 line-clamp-2 mb-2 group-hover:text-sky-600 dark:group-hover:text-sky-400 transition-colors">{rp.title || 'Tanpa Judul'}</h3>
                    <p class="mt-auto text-xs leading-relaxed text-slate-500 dark:text-slate-400 line-clamp-2">{rp.excerpt || (rp.content ? rp.content.slice(0, 100) + '...' : '')}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

      </article>
    ) : (
      <div class="mt-10 rounded-3xl border border-slate-200 bg-slate-50 p-10 text-center text-slate-700 shadow-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-200">
        <h2 class="text-2xl font-semibold">Artikel tidak ditemukan</h2>
        <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">Slug artikel tidak valid atau artikel belum tersedia.</p>
      </div>
    )}
  </section>
</Layout>

<style is:global>
  /* Fallback Typography (If @tailwindcss/typography is not installed) */
  .prose-content {
    color: #334155;
    line-height: 1.75;
    white-space: pre-line;
  }
  .dark .prose-content {
    color: #cbd5e1;
  }
  .prose-content h2 {
    color: #0f172a;
    font-weight: 700;
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    line-height: 1.3;
    scroll-margin-top: 6rem;
  }
  .dark .prose-content h2 {
    color: #f8fafc;
  }
  .prose-content h3 {
    color: #0f172a;
    font-weight: 600;
    font-size: 1.35rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    line-height: 1.4;
    scroll-margin-top: 6rem;
  }
  .dark .prose-content h3 {
    color: #f8fafc;
  }
  .prose-content p {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .prose-content strong {
    color: #0f172a;
    font-weight: 600;
  }
  .dark .prose-content strong {
    color: #f8fafc;
  }
  .prose-content ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .prose-content li {
    margin-top: 0.5rem;
    margin-bottom: 0.5em;
  }

  /* TOC active state */
  .toc-link.toc-active {
    background-color: rgba(14, 165, 233, 0.1);
    color: #0284c7;
    font-weight: 700;
    border-left: 3px solid #0ea5e9;
  }
  :global(.dark) .toc-link.toc-active {
    background-color: rgba(14, 165, 233, 0.12);
    color: #38bdf8;
    border-left-color: #38bdf8;
  }
</style>

<script>
  function setupTocHighlight() {
    const tocLinks = document.querySelectorAll('.toc-link[data-target]');
    if (tocLinks.length === 0) return;

    const headingIds = Array.from(tocLinks).map(link => (link as HTMLElement).dataset.target!);
    const headingElements = headingIds
      .map(id => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (headingElements.length === 0) return;

    let currentActive = '';

    const observer = new IntersectionObserver(
      (entries) => {
        // Cari heading yang paling atas dan visible
        const visibleEntries = entries.filter(e => e.isIntersecting);
        
        if (visibleEntries.length > 0) {
          // Ambil yang paling atas (y terkecil)
          const topEntry = visibleEntries.reduce((prev, curr) =>
            prev.boundingClientRect.top < curr.boundingClientRect.top ? prev : curr
          );
          const id = topEntry.target.id;
          if (id !== currentActive) {
            currentActive = id;
            tocLinks.forEach(link => {
              const el = link as HTMLElement;
              if (el.dataset.target === id) {
                el.classList.add('toc-active');
              } else {
                el.classList.remove('toc-active');
              }
            });
          }
        }
      },
      {
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0,
      }
    );

    headingElements.forEach(el => observer.observe(el));

    // Smooth scroll for TOC clicks
    tocLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = (link as HTMLElement).dataset.target!;
        const target = document.getElementById(targetId);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Update URL hash without jumping
          history.pushState(null, '', `#${targetId}`);
        }
      });
    });
  }

  setupTocHighlight();
  document.addEventListener('astro:page-load', setupTocHighlight);
</script>
