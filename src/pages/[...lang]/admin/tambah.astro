---
import AdminLayout from '@components/admin/AdminLayout.astro';
import { supabase } from '../../../lib/db.js';
import fs from 'node:fs/promises';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { Buffer } from 'node:buffer';
export { getStaticPaths } from '@i18n/utils';
export const prerender = false;

type Souvenir = {
  id?: number;
  foto: string;
  nama: string;
  harga: number;
  min_order: number;
};

const { lang } = Astro.params;
const currentLocale = lang || Astro.currentLocale || 'en';
const dashboardUrl = `/blast/${currentLocale}/admin`;
const url = new URL(Astro.request.url);
const idParam = Number(url.searchParams.get('id'));
let souvenir: Souvenir = {
  foto: '',
  nama: '',
  harga: 0,
  min_order: 1,
};
let statusMessage = '';
let isEdit = false;

// Moving fs operations inside POST block to prevent Vercel 500 error on page load
if (idParam) {
  isEdit = true;
  try {
    const { data, error } = await supabase.from('souvenirs').select('*').eq('id', idParam).single();
    if (error) throw error;
    if (data) {
      souvenir = data as Souvenir;
    }
  } catch (error) {
    console.error('Gagal memuat souvenir untuk edit:', error);
    statusMessage = 'Gagal memuat data souvenir.';
  }
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  const nama = String(formData.get('nama') || '');
  const harga = Number(formData.get('harga') || 0);
  const min_order = Number(formData.get('min_order') || 1);
  let foto = souvenir.foto;

  const uploadedFile = formData.get('foto');
  if (uploadedFile instanceof File && uploadedFile.size > 0) {
    try {
      const arrayBuffer = await uploadedFile.arrayBuffer();
      const base64String = Buffer.from(arrayBuffer).toString('base64');
      const mimeType = uploadedFile.type || 'image/jpeg';
      foto = `data:${mimeType};base64,${base64String}`;
    } catch (err) {
      console.error('File upload failed (likely due to read-only filesystem on Vercel):', err);
      // Fallback or warning could be set here
    }
  }

  try {
    if (action === 'save') {
      if (idParam) {
        const { error: updateError } = await supabase
          .from('souvenirs')
          .update({ foto, nama, harga, min_order })
          .eq('id', idParam);
        if (updateError) throw updateError;
        statusMessage = 'Souvenir berhasil diperbarui.';
      } else {
        const { error: insertError } = await supabase
          .from('souvenirs')
          .insert([{ foto, nama, harga, min_order }]);
        if (insertError) throw insertError;
        statusMessage = 'Souvenir baru berhasil ditambahkan.';
        souvenir = { foto: '', nama: '', harga: 0, min_order: 1 };
      }
    }
  } catch (error) {
    console.error('Gagal menyimpan souvenir:', error);
    statusMessage = 'Terjadi kesalahan saat menyimpan souvenir.';
  }
}
---

<AdminLayout currentLocale={currentLocale} activeMenu="tambah" pageTitle={isEdit ? 'Edit Souvenir' : 'Tambah Souvenir'}>

  <!-- Header Section -->
  <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
     <div>
       <p class="text-[10px] font-bold text-cyan-600 dark:text-cyan-400 uppercase tracking-[0.2em] mb-1">
         {isEdit ? 'Inventory Management' : 'New Product'}
       </p>
       <h1 class="text-3xl font-black text-slate-900 dark:text-slate-100 mb-2 tracking-tight">
         {isEdit ? 'Edit Souvenir' : 'Tambah Souvenir Baru'}
       </h1>
       <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">
         {isEdit ? 'Perbarui detail informasi souvenir yang sudah ada di sistem.' : 'Masukkan souvenir baru ke dalam daftar inventaris.'}
       </p>
     </div>
     <div class="flex gap-3">
       <a href={dashboardUrl} class="px-5 py-2.5 bg-slate-200 dark:bg-[#1c2541] hover:bg-slate-300 dark:hover:bg-[#222c4a] border border-transparent dark:border-[#2a3454] text-slate-700 dark:text-slate-300 text-sm font-bold rounded-lg transition-colors flex items-center gap-2 shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Kembali
       </a>
     </div>
  </header>

  <!-- Notification Alert -->
  {statusMessage ? (
    <div class="mb-8 p-4 bg-emerald-100 dark:bg-emerald-500/10 border border-emerald-300 dark:border-emerald-500/20 text-emerald-700 dark:text-emerald-400 rounded-xl flex items-center gap-3 text-sm font-bold shadow-lg transition-colors duration-300">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      {statusMessage}
    </div>
  ) : null}

  <!-- Form Section -->
  <div class="max-w-3xl bg-white dark:bg-[#1c2541] rounded-2xl p-8 border border-slate-200 dark:border-[#2a3454] shadow-xl transition-colors duration-300">
    <form method="POST" enctype="multipart/form-data" class="space-y-6">
      <input type="hidden" name="action" value="save" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label class="block text-sm font-bold text-slate-700 dark:text-slate-300">
            Nama Souvenir <span class="text-red-500">*</span>
          </label>
          <input 
            type="text" 
            name="nama" 
            value={souvenir.nama} 
            required 
            class="w-full px-4 py-3 bg-slate-50 dark:bg-[#0b1329] border border-slate-300 dark:border-[#2a3454] text-slate-900 dark:text-white rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all placeholder-slate-400 dark:placeholder-slate-500"
            placeholder="Masukkan nama produk..."
          />
        </div>

        <div class="space-y-2">
          <label class="block text-sm font-bold text-slate-700 dark:text-slate-300">
            Harga (IDR) <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 font-semibold">Rp</span>
            <input 
              type="number" 
              name="harga" 
              value={souvenir.harga} 
              min="0" 
              required 
              class="w-full pl-12 pr-4 py-3 bg-slate-50 dark:bg-[#0b1329] border border-slate-300 dark:border-[#2a3454] text-slate-900 dark:text-white rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all"
              placeholder="0"
            />
          </div>
        </div>
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300">
          Minimal Order <span class="text-red-500">*</span>
        </label>
        <div class="relative w-full md:w-1/2">
          <input 
            type="number" 
            name="min_order" 
            value={souvenir.min_order} 
            min="1" 
            required 
            class="w-full pr-12 pl-4 py-3 bg-slate-50 dark:bg-[#0b1329] border border-slate-300 dark:border-[#2a3454] text-slate-900 dark:text-white rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all"
          />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 font-semibold text-sm">pcs</span>
        </div>
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300">
          Foto Souvenir
        </label>
        <div class="w-full relative">
          <input 
            type="file" 
            name="foto" 
            id="foto-input"
            accept="image/*" 
            class="w-full px-4 py-3 bg-slate-50 dark:bg-[#0b1329] border border-slate-300 dark:border-[#2a3454] text-slate-900 dark:text-white rounded-xl focus:ring-2 focus:ring-cyan-500 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-cyan-100 file:text-cyan-700 dark:file:bg-cyan-500/20 dark:file:text-cyan-400 hover:file:bg-cyan-200 dark:hover:file:bg-cyan-500/30 cursor-pointer"
          />
        </div>
      </div>

      <div id="preview-container" class={`space-y-2 p-4 bg-slate-50 dark:bg-[#0b1329] rounded-xl border border-slate-200 dark:border-[#2a3454] ${isEdit && souvenir.foto ? '' : 'hidden'}`}>
        <p id="preview-text" class="text-xs font-bold text-slate-500 uppercase tracking-widest">
          {isEdit && souvenir.foto ? 'Preview Foto Saat Ini' : 'Preview Foto Baru'}
        </p>
        <img id="foto-preview" src={isEdit && souvenir.foto ? souvenir.foto : '#'} data-original={isEdit && souvenir.foto ? souvenir.foto : ''} alt="Preview foto souvenir" class="w-32 h-32 object-cover rounded-lg border border-slate-300 dark:border-[#2a3454] shadow-md" />
      </div>

      <div class="pt-6 border-t border-slate-200 dark:border-[#2a3454] flex gap-4">
        <button type="submit" class="px-6 py-3 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-bold rounded-xl shadow-[0_0_15px_rgba(6,182,212,0.4)] hover:shadow-[0_0_25px_rgba(6,182,212,0.6)] transition-all flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          {isEdit ? 'Simpan Perubahan' : 'Simpan Souvenir'}
        </button>
      </div>
    </form>
  </div>

</AdminLayout>

<script>
  function setupImagePreview() {
    const fotoInput = document.getElementById('foto-input') as HTMLInputElement;
    const previewContainer = document.getElementById('preview-container');
    const fotoPreview = document.getElementById('foto-preview') as HTMLImageElement;
    const previewText = document.getElementById('preview-text');

    if (fotoInput && previewContainer && fotoPreview) {
      fotoInput.addEventListener('change', function() {
        const file = fotoInput.files?.[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(e) {
            if (e.target && e.target.result) {
              fotoPreview.src = e.target.result.toString();
              previewContainer.classList.remove('hidden');
              if (previewText) {
                previewText.textContent = 'Preview Foto Baru';
              }
            }
          };
          reader.readAsDataURL(file);
        } else {
          const originalSrc = fotoPreview.getAttribute('data-original');
          if (originalSrc) {
            fotoPreview.src = originalSrc;
            if (previewText) {
              previewText.textContent = 'Preview Foto Saat Ini';
            }
          } else {
            previewContainer.classList.add('hidden');
            fotoPreview.src = '#';
          }
        }
      });
    }
  }

  // Setup event listener on initial load and view transitions
  setupImagePreview();
  document.addEventListener('astro:page-load', setupImagePreview);
</script>
