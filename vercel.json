{
    "rewrites": [
        {
            "source": "/blast/_astro/:path*",
            "destination": "/_astro/:path*"
        },
        {
            "source": "/blast/_image",
            "destination": "/_image"
        },
        {
            "source": "/blast/uploads/:path*",
            "destination": "/uploads/:path*"
        },
        {
            "source": "/blast/favicon.ico",
            "destination": "/favicon.ico"
        },
        {
            "source": "/blast/apple-touch-icon.png",
            "destination": "/apple-touch-icon.png"
        },
        {
            "source": "/blast/logo.svg",
            "destination": "/logo.svg"
        }
    ],
    "redirects": [
        {
            "source": "/",
            "destination": "/blast/id",
            "permanent": true
        },
        {
            "source": "/blast",
            "destination": "/blast/id",
            "permanent": true
        }
    ]
}