{
	"version": 3,
	"routes": [
		{
			"src": "^/blastadmin$",
			"headers": {
				"Location": "/blast/en/admin"
			},
			"status": 301
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/test-contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/test-db/?$",
			"dest": "_render"
		},
		{
			"src": "^/test-diagnostic/?$",
			"dest": "_render"
		},
		{
			"src": "^/test-insert/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/404/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/about/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/admin/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/admin/edit/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/admin/pesan/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/admin/tambah/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/blog-detail/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/legal/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/pricing/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/privacy/?$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/styleguide/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}